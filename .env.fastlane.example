# Copy this to .env.fastlane and fill in your values
# NEVER commit .env.fastlane to git

# Your Apple ID email
APPLE_ID=yaoyingshakewin@gmail.com

# App Store Connect Team ID (find at appstoreconnect.apple.com → Users & Access)
ITC_TEAM_ID=your_itc_team_id

# App Store Connect API Key (create at appstoreconnect.apple.com → Users & Access → Keys)
ASC_KEY_ID=XXXXXXXXXX
ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ASC_KEY_FILEPATH=./AuthKey_XXXXXXXXXX.p8
